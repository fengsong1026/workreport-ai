# WorkReport AI 环境变量示例
#
# 复制为 .env 并填入实际值

# SQLite 数据库路径（相对于项目根目录）
# 本地开发：file:./dev.db
# Docker 部署：file:./data/db/prod.db（挂载到 ./data/db 持久化）
DATABASE_URL="file:./dev.db"

# OpenAI 兼容 API 配置
# 也可在 Web UI 配置页设置，会覆盖此处
OPENAI_API_KEY="sk-your-api-key-here"
OPENAI_API_BASE="https://api.deepseek.com"
OPENAI_MODEL="deepseek-v4-flash"

# GitHub OAuth 配置
# 1. 前往 https://github.com/settings/developers → OAuth Apps → New OAuth App
# 2. Authorization callback URL 填: http://<你的访问地址>/api/oauth/callback/github
#    （本地: http://localhost:8907/api/oauth/callback/github，服务器: http://<IP>:8088/api/oauth/callback/github）
# 3. 将生成的 Client ID 和 Client Secret 填入下方
# 4. GITHUB_REDIRECT_URI 只配 path，运行时自动从请求推导 origin 拼接，
#    本地/服务器/任意域名都不用改此配置
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GITHUB_REDIRECT_URI="/api/oauth/callback/github"

# GitLab - https://docs.gitlab.com/ee/api/oauth2.html
GITLAB_CLIENT_ID=""
GITLAB_CLIENT_SECRET=""

# ─── 其他数据源 OAuth 配置 ───
# 每个 provider 需要 CLIENT_ID 和 CLIENT_SECRET
# 前往各平台注册 OAuth App，回调地址统一填:
#   http://<你的访问地址>/api/oauth/callback/<provider>
# （本地: http://localhost:8907，Docker: http://<IP>:8088）
# redirect_uri 运行时自动拼接，无需在此配置

# Jira (Atlassian) - https://developer.atlassian.com/cloud/jira/platform/oauth-2-3lo-apps/
JIRA_CLIENT_ID=""
JIRA_CLIENT_SECRET=""

# Linear - https://developers.linear.app/docs/oauth/authentication
LINEAR_CLIENT_ID=""
LINEAR_CLIENT_SECRET=""

# 飞书 - https://open.feishu.cn/document/uAjLw4CM/ukTMukTMukTM/reference/authen-v1/authorize
# 注意：飞书 OAuth 非标准流程，暂未实现自动连接
FEISHU_CLIENT_ID=""
FEISHU_CLIENT_SECRET=""

# Google Calendar - https://developers.google.com/calendar/auth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# 企业微信 - https://developer.work.weixin.qq.com/document/path/91022
# 注意：企业微信 OAuth 非标准流程，暂未实现自动连接
WECOM_CLIENT_ID=""
WECOM_CLIENT_SECRET=""

# Notion - https://developers.notion.com/docs/authorization
NOTION_CLIENT_ID=""
NOTION_CLIENT_SECRET=""

# 语雀 - https://www.yuque.com/yuque/developer/oauth
YUQUE_CLIENT_ID=""
YUQUE_CLIENT_SECRET=""

# JWT 密钥（生产环境必须修改为随机字符串）
JWT_SECRET="dev-secret-change-me"
