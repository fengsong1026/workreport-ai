# WorkReport AI 环境变量示例
#
# 复制为 .env 并填入实际值

# SQLite 数据库路径（相对于项目根目录）
# 本地开发：file:./dev.db
# Docker 部署：file:./data/db/prod.db（挂载到 ./data/db 持久化）
DATABASE_URL="file:./dev.db"

# OpenAI 兼容 API 配置
# 也可在 Web UI 配置页设置，会覆盖此处
OPENAI_API_KEY="sk-your-api-key-here"
OPENAI_API_BASE="https://api.deepseek.com"
OPENAI_MODEL="deepseek-v4-flash"

# GitHub OAuth 配置
# 1. 前往 https://github.com/settings/developers → OAuth Apps → New OAuth App
# 2. Authorization callback URL 填: http://localhost:3000/api/oauth/callback/github
# 3. 将生成的 Client ID 和 Client Secret 填入下方
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GITHUB_REDIRECT_URI="http://localhost:3000/api/oauth/callback/github"
